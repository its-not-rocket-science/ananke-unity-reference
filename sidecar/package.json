{
  "name": "ananke-unity-sidecar",
  "version": "0.2.0",
  "type": "module",
  "description": "Ananke physics sidecar for Unity 6 and Godot 4",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test:bridge": "npm run build && node scripts/verify-bridge.mjs",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "smoke": "npm run build && node scripts/smoke-test.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@its-not-rocket-science/ananke": "^0.1.15"
  }
}
