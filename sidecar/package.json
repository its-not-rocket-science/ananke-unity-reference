{
  "name": "ananke-unity-sidecar",
  "version": "0.1.0",
  "type": "module",
  "description": "Ananke physics sidecar for Unity 6",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "smoke": "npm run build && node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@its-not-rocket-science/ananke": "^0.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.4"
  }
}
