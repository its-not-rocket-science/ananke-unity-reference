%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!91 &9100000
AnimatorController:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_Name: AnankeAnimatorController
  serializedVersion: 5
  m_AnimatorParameters:
  # ── Primary state (integer) ─────────────────────────────────────────────
  # 0 = Idle, 1 = Guard, 2 = Attack, 3 = Prone, 4 = KO, 5 = Dead
  # Driven by AnankeAnimationHints.PrimaryStateCode in AnimationDriver.cs
  - m_Name: PrimaryState
    m_Type: 3
    m_DefaultFloat: 0
    m_DefaultInt: 0
    m_DefaultBool: 0
    m_Controller: {fileID: 9100000}
  # ── Locomotion blend (float 0–1) ────────────────────────────────────────
  # Max of walk/run/sprint/crawl normalised Q values.
  # Wire to a 1D blend tree: 0=Idle, 0.3=Walk, 0.6=Run, 1.0=Sprint
  - m_Name: Speed
    m_Type: 1
    m_DefaultFloat: 0
    m_DefaultInt: 0
    m_DefaultBool: 0
    m_Controller: {fileID: 9100000}
  # ── Combat blend weights (float 0–1) ────────────────────────────────────
  - m_Name: GuardWeight
    m_Type: 1
    m_DefaultFloat: 0
    m_DefaultInt: 0
    m_DefaultBool: 0
    m_Controller: {fileID: 9100000}
  - m_Name: AttackWeight
    m_Type: 1
    m_DefaultFloat: 0
    m_DefaultInt: 0
    m_DefaultBool: 0
    m_Controller: {fileID: 9100000}
  # ── Condition overlays (float 0–1) ──────────────────────────────────────
  # Drive additive/override layers for stagger, fear, injury deformation
  - m_Name: ShockBlend
    m_Type: 1
    m_DefaultFloat: 0
    m_DefaultInt: 0
    m_DefaultBool: 0
    m_Controller: {fileID: 9100000}
  - m_Name: FearBlend
    m_Type: 1
    m_DefaultFloat: 0
    m_DefaultInt: 0
    m_DefaultBool: 0
    m_Controller: {fileID: 9100000}
  - m_Name: InjuryBlend
    m_Type: 1
    m_DefaultFloat: 0
    m_DefaultInt: 0
    m_DefaultBool: 0
    m_Controller: {fileID: 9100000}
  # ── Boolean state flags ─────────────────────────────────────────────────
  # Snap at interpolation t >= 0.5 — do not lerp booleans
  - m_Name: IsProne
    m_Type: 4
    m_DefaultFloat: 0
    m_DefaultInt: 0
    m_DefaultBool: 0
    m_Controller: {fileID: 9100000}
  - m_Name: IsUnconscious
    m_Type: 4
    m_DefaultFloat: 0
    m_DefaultInt: 0
    m_DefaultBool: 0
    m_Controller: {fileID: 9100000}
  - m_Name: IsDead
    m_Type: 4
    m_DefaultFloat: 0
    m_DefaultInt: 0
    m_DefaultBool: 0
    m_Controller: {fileID: 9100000}
  m_AnimatorLayers:
  # ── Base Layer ──────────────────────────────────────────────────────────
  # PrimaryState integer drives the top-level state machine.
  # Add a 1D blend tree on 'Speed' inside the Idle and Walk/Run/Sprint states
  # for locomotion blending.
  - serializedVersion: 5
    m_Name: Base Layer
    m_StateMachine: {fileID: 1107587536}
    m_Mask: {fileID: 0}
    m_Motions: []
    m_Behaviours: []
    m_BlendingMode: 0
    m_SyncedLayerIndex: -1
    m_DefaultWeight: 0
    m_IKPass: 0
    m_SyncedLayerAffectsTiming: 0
    m_Controller: {fileID: 9100000}
  # ── Combat Override Layer ───────────────────────────────────────────────
  # Override layer weight driven by max(GuardWeight, AttackWeight).
  # Set blending mode to Override; weight set from script if needed,
  # or wire transitions from PrimaryState == 1 / 2.
  - serializedVersion: 5
    m_Name: Combat
    m_StateMachine: {fileID: 1107587537}
    m_Mask: {fileID: 0}
    m_Motions: []
    m_Behaviours: []
    m_BlendingMode: 0
    m_SyncedLayerIndex: -1
    m_DefaultWeight: 0
    m_IKPass: 0
    m_SyncedLayerAffectsTiming: 0
    m_Controller: {fileID: 9100000}
  # ── Shock Additive Overlay Layer ────────────────────────────────────────
  # Additive layer; ShockBlend drives a stagger/flinch clip weight.
  # Set blending mode to Additive in the inspector.
  - serializedVersion: 5
    m_Name: ShockOverlay
    m_StateMachine: {fileID: 1107587538}
    m_Mask: {fileID: 0}
    m_Motions: []
    m_Behaviours: []
    m_BlendingMode: 1
    m_SyncedLayerIndex: -1
    m_DefaultWeight: 0
    m_IKPass: 0
    m_SyncedLayerAffectsTiming: 0
    m_Controller: {fileID: 9100000}
